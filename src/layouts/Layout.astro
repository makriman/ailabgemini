---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { 
  title = "LBS AI Lab — The AI Venture Lab for Future Operators and Founders", 
  description = "LBS AI Lab is a selective building environment under the Data Science & AI Initiative at London Business School, helping future leaders learn AI by building real products."
} = Astro.props;

const currentPath = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/' && currentPath === '/') return true;
  if (path !== '/' && currentPath.startsWith(path)) return true;
  return false;
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Premium SEO Meta tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    
    <style>
      /* Layout-specific critical styles */
      .layout-wrapper {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      main {
        flex: 1 0 auto;
      }

      /* Premium Top Header bar */
      .header-top-banner {
        background-color: var(--color-lbs-blue);
        color: rgba(255, 255, 255, 0.85);
        font-size: var(--step--2);
        font-weight: 500;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding: 8px 0;
        border-bottom: 1px solid rgba(255, 255, 255, 0.15);
      }

      .header-top-banner .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .dsai-badge-link {
        color: var(--color-white);
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 6px;
        transition: var(--transition-fast);
      }

      .dsai-badge-link:hover {
        color: var(--color-lbs-red);
      }

      .dsai-badge-link span {
        width: 6px;
        height: 6px;
        background-color: var(--color-lbs-red);
        border-radius: 50%;
        display: inline-block;
      }

      /* Global premium header navigation */
      .global-header {
        background-color: var(--color-white);
        border-bottom: 2px solid var(--color-lbs-red);
        box-shadow: 0 4px 20px rgba(20, 23, 93, 0.04);
        position: sticky;
        top: 0;
        z-index: 1000;
        padding: 16px 0;
      }

      .global-header .container {
        display: flex;
        justify-content: space-between;
        align-items: center;
      }

      .logo-group {
        display: flex;
        flex-direction: column;
        text-decoration: none;
      }

      .logo-group .lab-name {
        font-family: var(--font-serif);
        font-size: var(--step-1);
        font-weight: 700;
        color: var(--color-lbs-blue);
        line-height: 1.1;
      }

      .logo-group .initiative-subtitle {
        font-family: var(--font-sans);
        font-size: var(--step--2);
        color: var(--color-muted);
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 2px;
      }

      .nav-menu {
        display: none;
        align-items: center;
        list-style: none;
        gap: clamp(12px, 2vw, 32px);
      }

      @media (min-width: 992px) {
        .nav-menu {
          display: flex;
        }
      }

      .nav-item a {
        font-family: var(--font-sans);
        font-size: var(--step--1);
        font-weight: 600;
        color: var(--color-ink-soft);
        text-decoration: none;
        padding: 8px 12px;
        position: relative;
        transition: var(--transition-fast);
      }

      .nav-item a::after {
        content: '';
        position: absolute;
        bottom: 0;
        left: 12px;
        right: 12px;
        height: 2px;
        background-color: var(--color-lbs-red);
        transform: scaleX(0);
        transition: var(--transition-smooth);
      }

      .nav-item a:hover {
        color: var(--color-lbs-blue);
      }

      .nav-item a:hover::after {
        transform: scaleX(1);
      }

      .nav-item.active a {
        color: var(--color-lbs-blue);
      }

      .nav-item.active a::after {
        transform: scaleX(1);
      }

      /* Mobile navigation toggle and menu overlay styling */
      .mobile-menu-toggle {
        display: inline-flex;
        background: none;
        border: 1px solid var(--color-border);
        padding: 8px 12px;
        cursor: pointer;
        font-family: var(--font-sans);
        font-size: var(--step--2);
        font-weight: bold;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-lbs-blue);
        transition: var(--transition-fast);
      }

      .mobile-menu-toggle:hover {
        background-color: var(--color-cloud);
        border-color: var(--color-lbs-blue);
      }

      @media (min-width: 992px) {
        .mobile-menu-toggle {
          display: none;
        }
      }

      .mobile-navigation-overlay {
        display: none;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: var(--color-lbs-blue);
        z-index: 9999;
        padding: 40px var(--gutter);
        flex-direction: column;
        justify-content: flex-start;
      }

      .mobile-navigation-overlay.open {
        display: flex;
      }

      .mobile-nav-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 48px;
        width: 100%;
      }

      .mobile-nav-header .lab-name {
        font-family: var(--font-serif);
        font-size: var(--step-1);
        font-weight: 700;
        color: var(--color-white);
      }

      .mobile-close-btn {
        background: none;
        border: 1px solid rgba(255, 255, 255, 0.3);
        color: var(--color-white);
        padding: 8px 16px;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        font-size: var(--step--2);
        cursor: pointer;
        transition: var(--transition-fast);
      }

      .mobile-close-btn:hover {
        background-color: rgba(255, 255, 255, 0.1);
        border-color: var(--color-white);
      }

      .mobile-nav-list {
        display: flex;
        flex-direction: column;
        gap: 24px;
        list-style: none;
      }

      .mobile-nav-list a {
        font-family: var(--font-serif);
        font-size: var(--step-2);
        color: rgba(255, 255, 255, 0.85);
        text-decoration: none;
        font-weight: 600;
        transition: var(--transition-fast);
      }

      .mobile-nav-list a:hover {
        color: var(--color-white);
        padding-left: 8px;
      }

      .mobile-nav-list .active a {
        color: var(--color-white);
        border-left: 3px solid var(--color-lbs-red);
        padding-left: 12px;
      }

      /* Premium Institutional Footer */
      .institutional-footer {
        background-color: var(--color-ink);
        color: var(--color-white);
        border-top: 4px solid var(--color-lbs-red);
      }

      .footer-main {
        padding-top: clamp(48px, 6vw, 80px);
        padding-bottom: clamp(48px, 6vw, 80px);
      }

      .footer-grid {
        display: grid;
        grid-template-columns: 1fr;
        gap: 48px;
      }

      @media (min-width: 768px) {
        .footer-grid {
          grid-template-columns: 1.5fr repeat(3, 1fr);
        }
      }

      .footer-brand {
        display: flex;
        flex-direction: column;
      }

      .footer-logo {
        font-family: var(--font-serif);
        font-size: var(--step-1);
        font-weight: 700;
        color: var(--color-white);
        line-height: 1.2;
        margin-bottom: 12px;
      }

      .footer-brand-tag {
        font-size: var(--step--1);
        color: rgba(255, 255, 255, 0.7);
        max-width: 32ch;
        margin-bottom: 24px;
        line-height: 1.5;
      }

      .footer-col-title {
        font-family: var(--font-sans);
        font-size: var(--step--1);
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        color: var(--color-white);
        margin-bottom: 20px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.15);
        padding-bottom: 8px;
        display: inline-block;
        width: 100%;
      }

      .footer-links {
        list-style: none;
        display: flex;
        flex-direction: column;
        gap: 12px;
      }

      .footer-links a {
        font-size: var(--step--1);
        color: rgba(255, 255, 255, 0.7);
        text-decoration: none;
        transition: var(--transition-fast);
      }

      .footer-links a:hover {
        color: var(--color-white);
        padding-left: 4px;
      }

      .footer-bottom {
        background-color: #0b0c2a;
        padding: 24px 0;
        font-size: var(--step--2);
        color: rgba(255, 255, 255, 0.55);
        border-top: 1px solid rgba(255, 255, 255, 0.08);
      }

      .footer-bottom .container {
        display: flex;
        flex-direction: column;
        gap: 16px;
      }

      @media (min-width: 768px) {
        .footer-bottom .container {
          flex-direction: row;
          justify-content: space-between;
          align-items: center;
        }
      }

      .footer-bottom-links {
        display: flex;
        gap: 24px;
        list-style: none;
      }

      .footer-bottom-links a {
        color: rgba(255, 255, 255, 0.55);
        text-decoration: none;
      }

      .footer-bottom-links a:hover {
        color: var(--color-white);
      }
    </style>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>

    <div class="layout-wrapper">
      <div class="header-top-banner" role="status">
        <div class="container">
          <span>London Business School · Institution Profile</span>
          <a href="https://www.london.edu/faculty-and-research/data-science-and-ai-initiative" target="_blank" rel="noopener noreferrer" class="dsai-badge-link">
            <span></span> DSAI Initiative
          </a>
        </div>
      </div>

      <header class="global-header">
        <div class="container">
          <a href="/" class="logo-group">
            <span class="lab-name">LBS AI Lab</span>
            <span class="initiative-subtitle">Data Science & AI Initiative</span>
          </a>

          <nav aria-label="Main Navigation">
            <ul class="nav-menu">
              <li class={`nav-item ${isActive('/about') ? 'active' : ''}`}><a href="/about/">About</a></li>
              <li class={`nav-item ${isActive('/cohorts') ? 'active' : ''}`}><a href="/cohorts/">Cohorts</a></li>
              <li class={`nav-item ${isActive('/teams') ? 'active' : ''}`}><a href="/teams/">Teams</a></li>
              <li class={`nav-item ${isActive('/mentors') ? 'active' : ''}`}><a href="/mentors/">Mentors</a></li>
              <li class={`nav-item ${isActive('/apply') ? 'active' : ''}`}><a href="/apply/">Apply</a></li>
              <li style="margin-left: 8px;">
                <a href="/apply/" class="btn btn-primary" style="padding: 8px 20px; font-size: var(--step--2);">Register Interest</a>
              </li>
            </ul>
          </nav>

          <button class="mobile-menu-toggle" id="mobile-menu-btn" aria-expanded="false" aria-controls="mobile-overlay-menu">
            Menu
          </button>
        </div>
      </header>

      <!-- Mobile Navigation Overlay -->
      <div class="mobile-navigation-overlay" id="mobile-overlay-menu">
        <div class="mobile-nav-header">
          <span class="lab-name">LBS AI Lab</span>
          <button class="mobile-close-btn" id="mobile-close-btn">Close</button>
        </div>
        <nav aria-label="Mobile Navigation">
          <ul class="mobile-nav-list">
            <li class={isActive('/') ? 'active' : ''}><a href="/">Home</a></li>
            <li class={isActive('/about') ? 'active' : ''}><a href="/about/">About</a></li>
            <li class={isActive('/cohorts') ? 'active' : ''}><a href="/cohorts/">Cohorts</a></li>
            <li class={isActive('/teams') ? 'active' : ''}><a href="/teams/">Teams</a></li>
            <li class={isActive('/mentors') ? 'active' : ''}><a href="/mentors/">Mentors</a></li>
            <li class={isActive('/apply') ? 'active' : ''}><a href="/apply/">Apply</a></li>
            <li class={isActive('/contact') ? 'active' : ''}><a href="/contact/">Contact</a></li>
            <li style="margin-top: 24px;">
              <a href="/apply/" class="btn btn-primary" style="display: block; text-align: center; color: white;">Apply for Cohort 02</a>
            </li>
          </ul>
        </nav>
      </div>

      <main id="main-content">
        <slot />
      </main>

      <footer class="institutional-footer">
        <div class="footer-main container">
          <div class="footer-grid">
            <div class="footer-brand">
              <span class="footer-logo">LBS AI Lab</span>
              <p class="footer-brand-tag">
                The AI venture lab for future operators and founders. Providing hands-on building experience for leaders navigating the future of AI.
              </p>
              <a href="/apply/" class="btn btn-primary" style="align-self: flex-start;">Register Interest</a>
            </div>

            <div>
              <span class="footer-col-title">Cohorts</span>
              <ul class="footer-links">
                <li><a href="/cohorts/cohort-01/">Cohort 01 (Spring 2026)</a></li>
                <li><a href="/cohorts/cohort-02/">Cohort 02 (Autumn 2026)</a></li>
                <li><a href="/cohorts/">All Cohorts</a></li>
              </ul>
            </div>

            <div>
              <span class="footer-col-title">Resources</span>
              <ul class="footer-links">
                <li><a href="/about/">About the Lab</a></li>
                <li><a href="/teams/">Product Roster</a></li>
                <li><a href="/mentors/">Technical Mentors</a></li>
                <li><a href="/contact/">Contact Details</a></li>
              </ul>
            </div>

            <div>
              <span class="footer-col-title">Institution</span>
              <ul class="footer-links">
                <li><a href="https://www.london.edu/" target="_blank" rel="noopener noreferrer">London Business School</a></li>
                <li><a href="https://www.london.edu/faculty-and-research/data-science-and-ai-initiative" target="_blank" rel="noopener noreferrer">Data Science & AI Initiative</a></li>
                <li><a href="/about/#dsai-alignment">Intellectual Framework</a></li>
              </ul>
            </div>
          </div>
        </div>

        <div class="footer-bottom">
          <div class="container">
            <div>
              &copy; {new Date().getFullYear()} LBS AI Lab. Part of the Data Science & AI Initiative at London Business School.
            </div>
            <ul class="footer-bottom-links">
              <li><a href="/contact/">Contact Us</a></li>
              <li><a href="https://www.london.edu/privacy-policy" target="_blank" rel="noopener noreferrer">Privacy Policy</a></li>
            </ul>
          </div>
        </div>
      </footer>
    </div>

    <!-- Client-side navigation helper scripts -->
    <script>
      const menuToggle = document.getElementById('mobile-menu-btn');
      const closeToggle = document.getElementById('mobile-close-btn');
      const mobileMenu = document.getElementById('mobile-overlay-menu');

      if (menuToggle && closeToggle && mobileMenu) {
        menuToggle.addEventListener('click', () => {
          mobileMenu.classList.add('open');
          menuToggle.setAttribute('aria-expanded', 'true');
        });

        closeToggle.addEventListener('click', () => {
          mobileMenu.classList.remove('open');
          menuToggle.setAttribute('aria-expanded', 'false');
        });

        // Close on escape key
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape' && mobileMenu.classList.contains('open')) {
            mobileMenu.classList.remove('open');
            menuToggle.setAttribute('aria-expanded', 'false');
            menuToggle.focus();
          }
        });
      }
    </script>
  </body>
</html>
