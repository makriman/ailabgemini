---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact LBS AI Lab — Institutional Channels" 
  description="Get in touch with the LBS AI Lab. Find official institutional channels for cohort queries, venture partnerships, and student builder sponsorships."
>
  <!-- Hero Section -->
  <section class="contact-hero" aria-label="Contact Introduction">
    <div class="container">
      <span class="badge badge-red" style="margin-bottom: 20px;">Institutional Communications</span>
      <h1 class="contact-headline">Contact LBS AI Lab.</h1>
      <p class="contact-subheadline">
        For questions about cohorts, mentoring, partnerships, or student-built AI products, contact the LBS AI Lab team.
      </p>
    </div>
  </section>

  <!-- Interactive Directory of Channels -->
  <section class="channels-section" aria-label="Communication Channels">
    <div class="container">
      <div class="channels-grid">
        <!-- Channel 01 -->
        <div class="channel-card">
          <h2 class="channel-title">Student Cohorts</h2>
          <p class="channel-desc">
            Are you a current London Business School student wondering about team formation, sandbox environments, or application requirements?
          </p>
          <div class="channel-action">
            <a href="/apply/" class="btn btn-secondary">Review application details &rarr;</a>
          </div>
        </div>

        <!-- Channel 02 -->
        <div class="channel-card">
          <h2 class="channel-title">Venture Mentorship</h2>
          <p class="channel-desc">
            Are you a technical founder, developer, or product strategist building with AI who wants to support future cohorts?
          </p>
          <div class="channel-action">
            <a href="/apply/" class="btn btn-secondary">Register as a Mentor &rarr;</a>
          </div>
        </div>

        <!-- Channel 03 -->
        <div class="channel-card">
          <h2 class="channel-title">DSAI Initiative Umbrella</h2>
          <p class="channel-desc">
            For academic collaborations, research inquiries, or official institutional partnerships with London Business School.
          </p>
          <div class="channel-action">
            <a href="https://www.london.edu/faculty-and-research/data-science-and-ai-initiative" target="_blank" rel="noopener noreferrer" class="btn btn-primary">Visit DSAI Portal &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Institutional Alignment statement -->
  <section class="alignment-box-section" aria-label="Location & Context">
    <div class="container asymmetrical-grid">
      <div>
        <span class="section-eyebrow">Institutional Address</span>
        <h2 class="section-title">Where we build</h2>
        <p>
          LBS AI Lab operates directly out of the London Business School campuses in London. 
        </p>
        <p class="location-details">
          <strong>London Business School</strong><br />
          Regent's Park, London NW1 4SA<br />
          United Kingdom
        </p>
      </div>

      <div class="location-sidebar">
        <div class="info-card">
          <h3 class="info-card-title">General Inquiries</h3>
          <p class="info-card-text">
            For general administrative inquiries, please contact the Data Science & AI Initiative administration office through official London Business School faculty directories.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Contact page specific styles */
  .contact-hero {
    background-color: var(--color-lbs-blue);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    color: var(--color-white);
    border-bottom: 6px solid var(--color-lbs-red);
  }

  .contact-headline {
    color: var(--color-white);
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    margin-bottom: 24px;
    line-height: 1.15;
  }

  .contact-subheadline {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-1);
    max-width: 800px;
    line-height: 1.5;
  }

  /* Channels styling */
  .channels-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .channels-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .channels-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .channel-card {
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-border);
    padding: clamp(24px, 4vw, 40px);
    display: flex;
    flex-direction: column;
    transition: var(--transition-smooth);
  }

  .channel-card:hover {
    box-shadow: var(--shadow-card);
    border-color: var(--color-lbs-blue);
  }

  .channel-title {
    font-size: var(--step-1);
    color: var(--color-lbs-blue);
    margin-bottom: 16px;
    border-bottom: 1px solid var(--color-border-strong);
    padding-bottom: 8px;
  }

  .channel-desc {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.6;
    margin-bottom: 32px;
    flex-grow: 1;
  }

  .channel-action {
    margin-top: auto;
  }

  /* Location block */
  .alignment-box-section {
    background-color: var(--color-warm-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
  }

  .location-details {
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--color-ink);
    margin-top: 24px;
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 24px;
    display: inline-block;
  }

  .location-sidebar {
    height: 100%;
    display: flex;
    align-items: center;
  }

  .info-card {
    background-color: var(--color-lbs-blue);
    color: var(--color-white);
    padding: 40px;
    border-top: 4px solid var(--color-lbs-red);
    width: 100%;
  }

  .info-card-title {
    color: var(--color-white);
    font-size: var(--step-1);
    margin-bottom: 16px;
    font-family: var(--font-serif);
  }

  .info-card-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step--1);
    line-height: 1.5;
    margin-bottom: 0;
  }
</style>
