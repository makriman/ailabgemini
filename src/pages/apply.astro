---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Apply for Cohort 02 — LBS AI Lab" 
  description="Apply to join Cohort 02 at LBS AI Lab. A hands-on building sandbox to learn vibe coding, deploy code, and test MVPs with 2,000 real LBS student users."
>
  <!-- Hero Section -->
  <section class="apply-hero" aria-label="Apply Introduction">
    <div class="container">
      <span class="badge badge-red" style="margin-bottom: 20px;">Register Interest</span>
      <h1 class="apply-headline">Build with the September 2026 cohort.</h1>
      <p class="apply-subheadline">
        LBS AI Lab is for students who want hands-on experience building AI products, automated workflows, and business prototypes, testing them with real users from day one.
      </p>
    </div>
  </section>

  <!-- Detailed Criteria sections (Reflecting Vibe-Coding Thesis) -->
  <section class="specs-section" aria-label="Cohort Guidelines">
    <div class="container asymmetrical-grid">
      <div class="specs-body">
        <h2 class="section-title">The Vibe-Coding Era</h2>
        <p class="specs-lead">
          AI-assisted coding and agentic engineering have made writing code fast and incredibly cheap.
        </p>
        <p>
          Because building technology has become accessible to everyone, **the largest technical and business challenge in software products is now getting real users, gathering feedback, and iterating based on that feedback.**
        </p>
        <p>
          LBS AI Lab is structured specifically to solve this challenge. All projects built in the lab must solve an **LBS use case**. This ensures every builder has direct, immediate access to an active fraternity of **2,000 LBS students** and a vast alumni network to test their builds, gather high-fidelity data, and iterate.
        </p>

        <h2 class="section-title" style="margin-top: 56px;">What you will do</h2>
        <p>
          During the 9-week sandbox, you will move systematically from scoping to a live, functional, public application:
        </p>
        <ul class="specs-list">
          <li>
            <strong>Form or join a team:</strong> Work in balanced squads replicating serious product development teams.
          </li>
          <li>
            <strong>Build fast with AI:</strong> We run technical sessions teaching you how to use modern LLM systems, code assistants, and serverless environments to build fast.
          </li>
          <li>
            <strong>Deploy to real LBS users:</strong> Share your live URL directly with the LBS student fraternity and gather user behavior logs.
          </li>
          <li>
            <strong>Iterate on real feedback:</strong> Work with technical and product mentors in review sessions to fix bugs, adjust features, and rebuild.
          </li>
        </ul>
      </div>

      <div class="specs-sidebar">
        <!-- Registration Form collecting name, email, course name -->
        <div class="apply-action-card">
          <h3 class="action-card-title">Register Cohort Interest</h3>
          <p class="action-card-text" style="margin-bottom: 24px;">
            Applications for Cohort 02 (Autumn 2026) will open in late summer. Submit your details today to receive workspace guides, team briefs, and timeline updates.
          </p>
          
          <form class="interest-form" id="cohort-interest-form" aria-label="Cohort Interest Form">
            <div class="form-group">
              <label for="student-name">Full Name</label>
              <input type="text" id="student-name" required placeholder="Jane Doe" />
            </div>
            <div class="form-group">
              <label for="student-email">LBS Email Address</label>
              <input type="email" id="student-email" required placeholder="jdoe.mba2027@london.edu" />
            </div>
            <div class="form-group">
              <label for="student-course">Course Name</label>
              <input type="text" id="student-course" required placeholder="e.g. MBA 2027 / MAM 2026" />
            </div>
            <button type="submit" class="btn btn-primary" style="display: block; width: 100%; margin-top: 24px; background-color: var(--color-lbs-red); color: white;">
              Submit Interest
            </button>
          </form>
          <div class="success-message" id="success-msg-box" style="display: none;">
            <strong>Registration Submitted!</strong><br />
            Thank you. Your details have been registered locally. We will contact you at your LBS email address with cohort updates.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- What you don't need -->
  <section class="qualifications-section" aria-label="Requirements Checklist">
    <div class="container">
      <div class="qual-card">
        <span class="section-eyebrow">Prerequisites</span>
        <h2 class="section-title">What you do not need</h2>
        <div class="qual-grid">
          <div class="qual-item">
            <strong>No professional software engineering background:</strong> We teach you how to vibe-code, manage context, and interact with LLM models.
          </div>
          <div class="qual-item">
            <strong>No prior project funding required:</strong> We supply the infrastructure models, database sandboxes, and vector nodes.
          </div>
          <div class="qual-item">
            <strong>What you DO need:</strong> Absolute discipline, an appetite to learn new ways of building, and a commitment to testing weekly with real users.
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Apply page specific styling */
  .apply-hero {
    background-color: var(--color-lbs-blue);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    color: var(--color-white);
    border-bottom: 6px solid var(--color-lbs-red);
  }

  .apply-headline {
    color: var(--color-white);
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    margin-bottom: 24px;
    line-height: 1.15;
  }

  .apply-subheadline {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-1);
    max-width: 800px;
    line-height: 1.5;
  }

  /* Specifications */
  .specs-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .specs-lead {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    color: var(--color-lbs-blue);
    margin-bottom: 24px;
    line-height: 1.5;
  }

  .specs-list {
    list-style: none;
    margin-top: 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .specs-list li {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.6;
    position: relative;
    padding-left: 24px;
  }

  .specs-list li::before {
    content: '▪';
    position: absolute;
    left: 0;
    color: var(--color-lbs-red);
    font-size: var(--step-0);
    line-height: 1;
  }

  /* Registration Form card */
  .specs-sidebar {
    height: 100%;
    display: flex;
    align-items: center;
  }

  .apply-action-card {
    background-color: var(--color-lbs-blue);
    color: var(--color-white);
    padding: clamp(24px, 4vw, 40px);
    border-top: 4px solid var(--color-lbs-red);
    width: 100%;
    box-shadow: var(--shadow-card);
  }

  .action-card-title {
    color: var(--color-white);
    font-size: var(--step-1);
    margin-bottom: 16px;
    font-family: var(--font-serif);
  }

  .action-card-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step--1);
    line-height: 1.5;
  }

  .interest-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 24px;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .form-group label {
    font-size: var(--step--2);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.7);
  }

  .form-group input {
    padding: 10px 14px;
    border-radius: var(--radius-badge);
    border: 1px solid rgba(255, 255, 255, 0.2);
    background-color: rgba(255, 255, 255, 0.08);
    color: var(--color-white);
    font-family: var(--font-sans);
    font-size: var(--step--1);
    transition: var(--transition-fast);
  }

  .form-group input::placeholder {
    color: rgba(255, 255, 255, 0.4);
  }

  .form-group input:focus {
    border-color: var(--color-lbs-red);
    background-color: rgba(255, 255, 255, 0.15);
    outline: none;
  }

  .success-message {
    font-size: var(--step--1);
    background-color: rgba(255, 255, 255, 0.1);
    border: 1px solid rgba(255, 255, 255, 0.2);
    padding: 24px;
    margin-top: 24px;
    line-height: 1.5;
  }

  /* Qualifications Section */
  .qualifications-section {
    background-color: var(--color-warm-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
  }

  .qual-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    padding: clamp(32px, 5vw, 64px);
    border-left: 6px solid var(--color-lbs-blue);
  }

  .qual-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    margin-top: 32px;
    border-top: 1px solid var(--color-border);
    padding-top: 32px;
  }

  @media (min-width: 768px) {
    .qual-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .qual-item {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.6;
  }

  .qual-item strong {
    color: var(--color-lbs-blue);
    display: block;
    margin-bottom: 8px;
  }
</style>

<!-- Active interest submission logic -->
<script>
  const formEl = document.getElementById('cohort-interest-form');
  const successBox = document.getElementById('success-msg-box');

  if (formEl && successBox) {
    formEl.addEventListener('submit', (e) => {
      e.preventDefault();
      // Animate success transition
      formEl.style.display = 'none';
      successBox.style.display = 'block';
    });
  }
</script>
