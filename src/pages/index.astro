---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import peopleData from '../data/people.json';

// Fetch team collections
const allTeams = await getCollection('teams');

// Define Cohort Metrics
const stats = {
  teams: 9,
  builders: 22,
  mentors: 4,
  timeline: "10 April - 12 June 2026"
};

// Filter featured teams
const featuredTeams = allTeams.filter(t => t.data.featured);

// Filter mentors from people seed data
const mentors = peopleData.filter(p => p.role === 'Mentor');
---

<Layout>
  <!-- 1. Hero Section (First Fold Optimized) -->
  <section class="hero-section" aria-label="Introduction">
    <div class="container asymmetrical-grid">
      <div class="hero-content">
        <span class="badge badge-red" style="margin-bottom: 20px;">Cohort 01 · In Partnership with Google DeepMind</span>
        <h1 class="hero-headline">The AI venture lab for future operators and founders.</h1>
        
        <div class="hero-intro-text">
          <p class="hero-subheadline">
            In the new era of agentic engineering, AI-assisted coding, and vibe coding, building software is easy, cheap, and at your fingertips.
          </p>
          <p class="hero-thesis-detail">
            The true bottleneck is no longer writing the code. The largest challenge is **getting real users, testing, gathering feedback, and iterating to build what people really want.** LBS AI Lab teaches you how to build fast and puts real users in front of your product from day one.
          </p>
        </div>

        <div class="hero-actions">
          <a href="#cohort-showcase" class="btn btn-primary">Explore Cohort 01</a>
          <a href="/apply/" class="btn btn-secondary">Register for Cohort 02</a>
        </div>
        <p class="hero-microcopy">Built by LBS students. Supported by the Data Science & AI Initiative.</p>
      </div>

      <!-- Cohort 01 Facts box with Google DeepMind Logo (Stunning visual design) -->
      <aside class="hero-panel" aria-label="Cohort 01 facts">
        <div class="panel-header-block">
          <span class="panel-eyebrow">Cohort 01</span>
          <strong class="panel-timeline">{stats.timeline}</strong>
        </div>
        
        <dl class="panel-metrics-list">
          <div class="panel-metric-item">
            <dt>Teams</dt>
            <dd>{stats.teams}</dd>
          </div>
          <div class="panel-metric-item">
            <dt>Builders</dt>
            <dd>{stats.builders}</dd>
          </div>
          <div class="panel-metric-item">
            <dt>Mentors</dt>
            <dd>{stats.mentors}</dd>
          </div>
        </dl>

        <div class="deepmind-alliance-badge">
          <span class="alliance-label">In Partnership With</span>
          <div class="logo-wrap">
            <img src="/deepmind_logo.svg" alt="Google DeepMind Logo" class="dm-hero-logo" />
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- 2. Manifesto Section (The Vibe-Coding Thesis) -->
  <section class="manifesto-section" aria-label="Manifesto">
    <div class="container">
      <div class="manifesto-box">
        <h2 class="manifesto-title">We believe the future's most effective leaders will be builders.</h2>
        <div class="manifesto-body">
          <p>
            With modern agentic AI systems, a single operator can design, build, and deploy custom tools in hours. The traditional friction of engineering is disappearing.
          </p>
          <p>
            To achieve this, **every project in LBS AI Lab must be built for a real London Business School use case.** By doing so, our builders gain direct access to a ready audience of 2,000 LBS students and a vast, global alumni network. 
          </p>
          <p>
            We teach you to build fast in this new era, provide you with active sandbox environments, and deliver a ready fraternity of real users to test, feedback, and iterate on what you construct.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Proof Metrics & Pillars -->
  <section class="pillars-section" aria-label="Our Pillars">
    <div class="container">
      <span class="section-eyebrow">Practical Competence</span>
      <h2 class="section-title">How the AI Lab works</h2>
      <p class="section-desc">
        We strip away slide decks and abstract concepts. We focus on training you in modern rapid development and matching your systems with real user workflows.
      </p>

      <div class="pillars-grid">
        <div class="pillar-card">
          <div class="pillar-num">01</div>
          <h3 class="pillar-heading">Vibe & Build Fast</h3>
          <p class="pillar-text">
            Learn to leverage agentic engineering and AI assistants. We teach you how to write prompts, generate configurations, and build functional MVPs at minimal cost in days.
          </p>
        </div>

        <div class="pillar-card">
          <div class="pillar-num">02</div>
          <h3 class="pillar-heading">Get Real Users</h3>
          <p class="pillar-text">
            Every product is built for an LBS use case. You launch directly to the 2,000 LBS student fraternity and alumni network, receiving immediate, high-fidelity feedback.
          </p>
        </div>

        <div class="pillar-card">
          <div class="pillar-num">03</div>
          <h3 class="pillar-heading">Iterate & Learn</h3>
          <p class="pillar-text">
            We run structured review sessions with technical and product experts, teaching you how to debug based on user behaviors, rebuild, and repeat.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Featured Teams Section (Trio Highlight) -->
  <section class="featured-teams-section" aria-label="Featured Teams">
    <div class="container">
      <span class="section-eyebrow">Strategic Highlights</span>
      <h2 class="section-title">Venture Spotlights</h2>
      <p class="section-desc">
        A curated selection demonstrating student experience, campus operations, and external venture potential.
      </p>

      <div class="featured-grid">
        {featuredTeams.map((team) => (
          <div class="featured-card">
            <div class="featured-card-content">
              <span class="badge badge-blue" style="margin-bottom: 12px;">{team.data.category}</span>
              <h3 class="featured-team-name">{team.data.name}</h3>
              <p class="featured-team-tagline">{team.data.tagline}</p>
              <p class="featured-team-desc">{team.data.summary}</p>
              
              <div class="featured-team-builders">
                <strong>Builders:</strong> {team.data.members.map(m => m.name).join(', ')}
              </div>

              <div class="featured-actions">
                <a href={`/teams/${team.id}/`} class="btn btn-secondary">Read Case Study</a>
                {team.data.productUrl && (
                  <a href={team.data.productUrl} target="_blank" rel="noopener noreferrer" class="product-link-icon">
                    Visit live site &rarr;
                  </a>
                )}
              </div>
            </div>
            <div class="featured-card-visual">
              <div class="visual-mock">
                <div class="mock-header">
                  <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                  <span class="mock-url">{team.id}.lbsailab.com</span>
                </div>
                <div class="mock-body">
                  <span class="mock-logo">{team.data.name}</span>
                  <span class="mock-tagline">{team.data.tagline}</span>
                  <div class="mock-blocks">
                    <div></div><div></div><div></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Cohort 01 Showcase (No Category Filters, actual builder names) -->
  <section class="cohort-showcase-section" id="cohort-showcase" aria-label="Cohort Showcase">
    <div class="container">
      <div class="showcase-header">
        <div>
          <span class="section-eyebrow">The Founding Batch</span>
          <h2 class="section-title">Cohort 01 Ventures</h2>
          <p class="section-desc" style="margin-bottom: 0;">
            Nine student teams building AI products in partnership with **Google DeepMind**, mapped to active LBS campus and professional use cases.
          </p>
        </div>
        <a href="/cohorts/cohort-01/" class="btn btn-secondary">View Cohort 01 Details</a>
      </div>

      <div class="showcase-grid">
        {allTeams.map(team => (
          <div class="team-card">
            <span class="team-card-category">{team.data.category}</span>
            <h3 class="team-card-title">{team.data.name}</h3>
            <p class="team-card-desc">{team.data.tagline}</p>
            
            <div class="team-builders-list">
              <strong>Builders:</strong>
              <span>{team.data.members.map(m => m.name).join(', ')}</span>
            </div>

            <div class="team-card-footer">
              <span class="cohort-partnership-tag">Google DeepMind partner</span>
              <a href={`/teams/${team.id}/`} class="team-card-link">Profile &rarr;</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. Mentor Layer -->
  <section class="mentors-section" aria-label="Mentorship">
    <div class="container">
      <span class="section-eyebrow">Expert Guidance</span>
      <h2 class="section-title">Technical & Product Mentors</h2>
      <p class="section-desc">
        Providing active guidance on quick tech stack integrations, scope refinement, and rapid visual iterations.
      </p>

      <div class="mentors-grid">
        {mentors.map(mentor => (
          <div class="mentor-card">
            <div class="mentor-info">
              <h3 class="mentor-name">{mentor.name}</h3>
              <span class="mentor-badge">{mentor.mentorType}</span>
            </div>
            <p class="mentor-desc">
              Helping builders deploy code, design API pathways, and evaluate user logs throughout the 9-week sandbox.
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. September 2026 CTA -->
  <section class="cta-section" aria-label="Call to Action">
    <div class="container">
      <div class="cta-box">
        <span class="badge badge-red" style="margin-bottom: 16px;">Cohort 02 Applications</span>
        <h2 class="cta-title">Build in the September 2026 cohort.</h2>
        <p class="cta-desc">
          Want to learn how to build fast using modern agentic systems, launch to 2,000 real LBS students, and iterate based on high-fidelity feedback? Register your interest today.
        </p>
        <div class="cta-actions">
          <a href="/apply/" class="btn btn-primary" style="background-color: var(--color-lbs-red); color: white;">Register Interest</a>
          <a href="/about/" class="btn btn-secondary" style="border-color: white; color: white;">Read Lab Thesis</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. LBS broader AI Research Alignment block -->
  <section class="dsai-alignment-section" aria-label="Institutional Alignment">
    <div class="container">
      <div class="dsai-align-box">
        <div class="dsai-align-content">
          <span class="section-eyebrow">Explore the School's broader research on AI</span>
          <h2 class="section-title" style="color: var(--color-white);">Alignment with London Business School's Broader Work on AI</h2>
          <p style="color: rgba(255, 255, 255, 0.85); max-width: 65ch;">
            The Data Science & AI Initiative at London Business School advances independent evidence, practical playbooks, and responsible adoption frameworks for leaders navigating AI. LBS AI Lab extends that mission into hands-on product building for students, training future business leaders to work directly with the systems shaping industry.
          </p>
          <a href="https://www.london.edu/faculty-and-research/data-science-and-ai-initiative" target="_blank" rel="noopener noreferrer" class="btn btn-secondary" style="border-color: var(--color-lbs-red); color: var(--color-white); background-color: var(--color-lbs-red);">
            Visit the DSAI Initiative Website
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* 1. Hero Styling (Optimized First Fold) */
  .hero-section {
    background-color: var(--color-lbs-blue);
    padding-top: clamp(48px, 6vw, 96px);
    padding-bottom: clamp(48px, 6vw, 96px);
    color: var(--color-white);
    border-bottom: 8px solid var(--color-lbs-red);
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 60%;
    height: 100%;
    background: radial-gradient(circle at 80% 20%, rgba(205, 13, 47, 0.12), transparent 60%);
    pointer-events: none;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-headline {
    color: var(--color-white);
    font-size: clamp(2rem, 4vw, 3.4rem);
    margin-bottom: 24px;
    line-height: 1.1;
  }

  .hero-intro-text {
    margin-bottom: 36px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .hero-subheadline {
    color: var(--color-white);
    font-size: var(--step-1);
    font-weight: 700;
    line-height: 1.4;
    font-family: var(--font-serif);
    margin-bottom: 0;
  }

  .hero-thesis-detail {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-0);
    line-height: 1.5;
    margin-bottom: 0;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 24px;
  }

  .hero-actions .btn-secondary {
    color: var(--color-white);
    border-color: var(--color-white);
  }

  .hero-actions .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: var(--color-lbs-red);
    color: var(--color-lbs-red);
  }

  .hero-microcopy {
    font-size: var(--step--2);
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0;
  }

  /* Stunning visual side panel for Cohort 01 facts & Google DeepMind Logo */
  .hero-panel {
    background-color: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.14);
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    backdrop-filter: blur(10px);
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.15);
  }

  .panel-header-block {
    display: flex;
    flex-direction: column;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    padding-bottom: 16px;
    margin-bottom: 24px;
  }

  .panel-eyebrow {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-lbs-red);
    font-weight: 700;
    margin-bottom: 4px;
  }

  .panel-timeline {
    font-size: var(--step-0);
    color: var(--color-white);
    font-family: var(--font-serif);
  }

  .panel-metrics-list {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-bottom: 32px;
  }

  .panel-metric-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    padding-bottom: 8px;
  }

  .panel-metric-item dt {
    font-size: var(--step--1);
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .panel-metric-item dd {
    font-size: var(--step-1);
    font-weight: 700;
    color: var(--color-white);
    font-family: var(--font-serif);
  }

  .deepmind-alliance-badge {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 20px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 8px;
  }

  .alliance-label {
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255, 255, 255, 0.55);
    font-weight: 700;
  }

  .logo-wrap {
    background-color: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 12px 20px;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: var(--transition-fast);
  }

  .logo-wrap:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .dm-hero-logo {
    height: 20px;
    max-width: 100%;
    filter: brightness(0) invert(1); /* Ensure it displays cleanly in white on dark bg */
  }

  /* 2. Manifesto Styling */
  .manifesto-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .manifesto-box {
    max-width: 900px;
    margin: 0 auto;
    border-left: 6px solid var(--color-lbs-red);
    padding-left: clamp(24px, 4vw, 48px);
  }

  .manifesto-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    line-height: 1.2;
    margin-bottom: 28px;
    color: var(--color-lbs-blue);
  }

  .manifesto-body p {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin-bottom: 20px;
    max-width: none;
  }

  /* Section Base Utility */
  .section-eyebrow {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--color-lbs-red);
    display: block;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: var(--step-3);
    color: var(--color-lbs-blue);
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .section-desc {
    font-size: var(--step-0);
    color: var(--color-ink-soft);
    margin-bottom: 48px;
    max-width: 65ch;
  }

  /* 3. Pillars Styling */
  .pillars-section {
    background-color: var(--color-warm-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .pillars-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pillar-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 40px;
    transition: var(--transition-smooth);
    position: relative;
  }

  .pillar-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--color-lbs-blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: var(--transition-smooth);
  }

  .pillar-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-card);
    border-color: transparent;
  }

  .pillar-card:hover::before {
    transform: scaleX(1);
  }

  .pillar-num {
    font-family: var(--font-serif);
    font-size: var(--step-2);
    font-weight: 700;
    color: var(--color-lbs-red);
    margin-bottom: 20px;
  }

  .pillar-heading {
    font-size: var(--step-1);
    color: var(--color-lbs-blue);
    margin-bottom: 12px;
  }

  .pillar-text {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* 4. Featured Teams Section */
  .featured-teams-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .featured-grid {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--color-border);
    background-color: var(--color-warm-white);
    transition: var(--transition-smooth);
  }

  @media (min-width: 992px) {
    .featured-card {
      grid-template-columns: 1.2fr 0.8fr;
    }
    .featured-card:nth-child(even) {
      grid-template-columns: 0.8fr 1.2fr;
    }
    .featured-card:nth-child(even) .featured-card-content {
      order: 2;
    }
    .featured-card:nth-child(even) .featured-card-visual {
      order: 1;
      border-right: 1px solid var(--color-border);
      border-left: none;
    }
  }

  .featured-card:hover {
    box-shadow: var(--shadow-card);
    border-color: var(--color-lbs-blue);
  }

  .featured-card-content {
    padding: clamp(32px, 5vw, 64px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  .featured-team-name {
    font-size: var(--step-2);
    color: var(--color-lbs-blue);
    margin-bottom: 12px;
  }

  .featured-team-tagline {
    font-size: var(--step-0);
    font-weight: 600;
    color: var(--color-lbs-red);
    margin-bottom: 20px;
    font-family: var(--font-sans);
  }

  .featured-team-desc {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    margin-bottom: 24px;
    line-height: 1.6;
  }

  .featured-team-builders {
    font-size: var(--step--2);
    color: var(--color-muted);
    margin-bottom: 32px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.4;
  }

  .featured-team-builders strong {
    color: var(--color-lbs-blue);
  }

  .featured-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
  }

  .product-link-icon {
    font-size: var(--step--1);
    font-weight: bold;
    color: var(--color-lbs-blue);
    text-decoration: none;
  }

  .product-link-icon:hover {
    color: var(--color-lbs-red);
  }

  .featured-card-visual {
    background-color: var(--color-cloud);
    border-left: 1px solid var(--color-border);
    padding: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .visual-mock {
    width: 100%;
    max-width: 380px;
    background-color: var(--color-white);
    border: 1px solid var(--color-border-strong);
    box-shadow: 0 12px 32px rgba(20, 23, 93, 0.06);
    display: flex;
    flex-direction: column;
  }

  .mock-header {
    background-color: var(--color-cloud);
    border-bottom: 1px solid var(--color-border);
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mock-header .dot {
    width: 6px;
    height: 6px;
    background-color: var(--color-border-strong);
    border-radius: 50%;
  }

  .mock-url {
    font-size: 10px;
    color: var(--color-muted);
    margin-left: 8px;
    font-family: var(--font-sans);
  }

  .mock-body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .mock-logo {
    font-family: var(--font-serif);
    font-size: var(--step-0);
    font-weight: 700;
    color: var(--color-lbs-blue);
    margin-bottom: 6px;
