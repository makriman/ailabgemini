---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import peopleData from '../data/people.json';

// Fetch team collections
const allTeams = await getCollection('teams');

// Define Cohort Metrics
const stats = {
  teams: 9,
  builders: 22,
  mentors: 4,
  duration: "9 weeks",
  timeline: "10 April - 12 June 2026"
};

// Filter featured teams
const featuredTeams = allTeams.filter(t => t.data.featured);

// Filter mentors from people seed data
const mentors = peopleData.filter(p => p.role === 'Mentor');
---

<Layout>
  <!-- 1. Hero Section -->
  <section class="hero-section" aria-label="Introduction">
    <div class="container asymmetrical-grid">
      <div class="hero-content">
        <span class="badge badge-red" style="margin-bottom: 20px;">London Business School · Data Science & AI Initiative</span>
        <h1 class="hero-headline">The AI venture lab for future operators and founders.</h1>
        <p class="hero-subheadline">
          LBS AI Lab gives students hands-on experience building AI products, automating workflows, and exploring how intelligent systems reshape business.
        </p>
        <div class="hero-actions">
          <a href="#cohort-showcase" class="btn btn-primary">Explore Cohort 01</a>
          <a href="/apply/" class="btn btn-secondary">Apply for September 2026</a>
        </div>
        <p class="hero-microcopy">Built by LBS students. Backed by the Data Science & AI Initiative.</p>
      </div>

      <div class="hero-side-panel">
        <span class="panel-eyebrow">Cohort 01 Status</span>
        <div class="panel-metric-row">
          <span class="panel-metric-value">{stats.teams}</span>
          <span class="panel-metric-label">Student Teams Scaffolding Prototypes</span>
        </div>
        <div class="panel-details-list">
          <div class="panel-detail-item">
            <strong>Timeline:</strong> {stats.timeline}
          </div>
          <div class="panel-detail-item">
            <strong>Participants:</strong> {stats.builders} Builders
          </div>
          <div class="panel-detail-item">
            <strong>Mentoring:</strong> {stats.mentors} Expert Mentors
          </div>
          <div class="panel-detail-item">
            <strong>Focus:</strong> Hands-on Product building
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. Manifesto Section -->
  <section class="manifesto-section" aria-label="Manifesto">
    <div class="container">
      <div class="manifesto-box">
        <h2 class="manifesto-title">We believe the future's most effective leaders will be builders.</h2>
        <div class="manifesto-body">
          <p>
            As AI reshapes every industry, the ability to prototype products, automate workflows, and work directly with intelligent systems becomes a strategic advantage.
          </p>
          <p>
            LBS AI Lab gives students a hands-on environment to explore that future through real products, real experiments, and real execution.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 3. Proof Metrics & Pillars -->
  <section class="pillars-section" aria-label="Our Pillars">
    <div class="container">
      <span class="section-eyebrow">Practical Competence</span>
      <h2 class="section-title">How the AI Lab works</h2>
      <p class="section-desc">
        We move past AI concepts and discussions. We provide the infrastructure and timeline for LBS students to learn AI by building.
      </p>

      <div class="pillars-grid">
        <div class="pillar-card">
          <div class="pillar-num">01</div>
          <h3 class="pillar-heading">Build</h3>
          <p class="pillar-text">
            Students move from idea to active prototype through intensive building cycles. We build with modern API frameworks and LLMs.
          </p>
        </div>

        <div class="pillar-card">
          <div class="pillar-num">02</div>
          <h3 class="pillar-heading">Experiment</h3>
          <p class="pillar-text">
            Teams deploy their prototypes to real campus cohorts, local businesses, and pilot users to gather feedback, data, and user behaviors.
          </p>
        </div>

        <div class="pillar-card">
          <div class="pillar-num">03</div>
          <h3 class="pillar-heading">Transform</h3>
          <p class="pillar-text">
            By building systems themselves, future business leaders develop deep technical fluency to drive strategic enterprise transformation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- 4. Featured Teams Section (Trio Highlight) -->
  <section class="featured-teams-section" aria-label="Featured Teams">
    <div class="container">
      <span class="section-eyebrow">Strategic Highlights</span>
      <h2 class="section-title">Venture Spotlights</h2>
      <p class="section-desc">
        A curated selection demonstrating student experience, campus operations, and external venture potential.
      </p>

      <div class="featured-grid">
        {featuredTeams.map((team, idx) => (
          <div class="featured-card">
            <div class="featured-card-content">
              <span class="badge badge-blue" style="margin-bottom: 12px;">{team.data.category}</span>
              <h3 class="featured-team-name">{team.data.name}</h3>
              <p class="featured-team-tagline">{team.data.tagline}</p>
              <p class="featured-team-desc">{team.data.summary}</p>
              <div class="featured-team-meta">
                <span><strong>Cohort:</strong> {team.data.cohortLabel}</span>
                <span><strong>Team Size:</strong> {team.data.members.length} Builders</span>
              </div>
              <div class="featured-actions">
                <a href={`/teams/${team.id}/`} class="btn btn-secondary">Read Case Study</a>
                {team.data.productUrl && (
                  <a href={team.data.productUrl} target="_blank" rel="noopener noreferrer" class="product-link-icon">
                    Visit live site &rarr;
                  </a>
                )}
              </div>
            </div>
            <div class="featured-card-visual">
              <div class="visual-mock">
                <div class="mock-header">
                  <span class="dot"></span><span class="dot"></span><span class="dot"></span>
                  <span class="mock-url">{team.id}.lbsailab.com</span>
                </div>
                <div class="mock-body">
                  <span class="mock-logo">{team.data.name}</span>
                  <span class="mock-tagline">{team.data.tagline}</span>
                  <div class="mock-blocks">
                    <div></div><div></div><div></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 5. Cohort 01 Showcase -->
  <section class="cohort-showcase-section" id="cohort-showcase" aria-label="Cohort Showcase">
    <div class="container">
      <div class="showcase-header">
        <div>
          <span class="section-eyebrow">The Roster</span>
          <h2 class="section-title">Meet the founding cohort</h2>
          <p class="section-desc" style="margin-bottom: 0;">
            Nine student teams building AI products across careers, local life, club operations, academic planning, and professional workflows.
          </p>
        </div>
        <a href="/cohorts/cohort-01/" class="btn btn-secondary">View cohort 01 batch</a>
      </div>

      <div class="showcase-grid">
        {allTeams.map(team => (
          <div class="team-card">
            <span class="team-card-category">{team.data.category}</span>
            <h3 class="team-card-title">{team.data.name}</h3>
            <p class="team-card-desc">{team.data.tagline}</p>
            <div class="team-card-footer">
              <span class="team-size">{team.data.members.length} builders</span>
              <a href={`/teams/${team.id}/`} class="team-card-link">Profile &rarr;</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 6. Mentor Layer -->
  <section class="mentors-section" aria-label="Mentorship">
    <div class="container">
      <span class="section-eyebrow">Expert Guidance</span>
      <h2 class="section-title">Technical & Product Mentors</h2>
      <p class="section-desc">
        Sharpening product direction, technical feasibility, and launch readiness throughout the build cycle.
      </p>

      <div class="mentors-grid">
        {mentors.map(mentor => (
          <div class="mentor-card">
            <div class="mentor-info">
              <h3 class="mentor-name">{mentor.name}</h3>
              <span class="mentor-badge">{mentor.mentorType}</span>
            </div>
            <p class="mentor-desc">
              Providing active feedback on stack construction, product scope, and user interface iterations for the founding cohort.
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- 7. September 2026 CTA -->
  <section class="cta-section" aria-label="Call to Action">
    <div class="container">
      <div class="cta-box">
        <span class="badge badge-red" style="margin-bottom: 16px;">Cohort 02 Applications</span>
        <h2 class="cta-title">Build in the September 2026 cohort.</h2>
        <p class="cta-desc">
          Applications will open for LBS students who want to build real AI products, work in ambitious teams, and develop the hands-on fluency needed to lead AI transformation.
        </p>
        <div class="cta-actions">
          <a href="/apply/" class="btn btn-primary" style="background-color: var(--color-lbs-red); color: white;">Register Interest</a>
          <a href="/about/" class="btn btn-secondary" style="border-color: white; color: white;">Learn More</a>
        </div>
      </div>
    </div>
  </section>

  <!-- 8. DSAI Alignment block -->
  <section class="dsai-alignment-section" aria-label="Institutional Alignment">
    <div class="container">
      <div class="dsai-align-box">
        <div class="dsai-align-content">
          <span class="section-eyebrow">Institutional Framework</span>
          <h2 class="section-title" style="color: var(--color-white);">Part of the Data Science & AI Initiative</h2>
          <p style="color: rgba(255, 255, 255, 0.85); max-width: 65ch;">
            The Data Science & AI Initiative at London Business School advances independent evidence, practical playbooks, and responsible adoption frameworks for leaders navigating AI. LBS AI Lab extends that mission into hands-on product building for students.
          </p>
          <a href="https://www.london.edu/faculty-and-research/data-science-and-ai-initiative" target="_blank" rel="noopener noreferrer" class="btn btn-secondary" style="border-color: var(--color-lbs-red); color: var(--color-white); background-color: var(--color-lbs-red);">
            Visit the DSAI Initiative website
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Premium Homepage specific styles */

  /* 1. Hero Styling */
  .hero-section {
    background-color: var(--color-lbs-blue);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    color: var(--color-white);
    border-bottom: 8px solid var(--color-lbs-red);
    position: relative;
    overflow: hidden;
  }

  .hero-section::before {
    content: '';
    position: absolute;
    top: 0;
    right: 0;
    width: 60%;
    height: 100%;
    background: radial-gradient(circle at 80% 20%, rgba(205, 13, 47, 0.12), transparent 60%);
    pointer-events: none;
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .hero-headline {
    color: var(--color-white);
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    margin-bottom: 24px;
    line-height: 1.1;
  }

  .hero-subheadline {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-1);
    margin-bottom: 40px;
    font-family: var(--font-sans);
    line-height: 1.5;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-bottom: 24px;
  }

  .hero-actions .btn-secondary {
    color: var(--color-white);
    border-color: var(--color-white);
  }

  .hero-actions .btn-secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
    border-color: var(--color-lbs-red);
    color: var(--color-lbs-red);
  }

  .hero-microcopy {
    font-size: var(--step--2);
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 0;
  }

  /* Side metrics panel */
  .hero-side-panel {
    background-color: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.15);
    padding: 32px;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .panel-eyebrow {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-lbs-red);
    font-weight: 700;
    margin-bottom: 16px;
  }

  .panel-metric-row {
    display: flex;
    flex-direction: column;
    margin-bottom: 24px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.15);
    padding-bottom: 20px;
  }

  .panel-metric-value {
    font-family: var(--font-serif);
    font-size: var(--step-4);
    font-weight: 700;
    line-height: 1;
    color: var(--color-white);
  }

  .panel-metric-label {
    font-size: var(--step--1);
    color: rgba(255, 255, 255, 0.7);
    margin-top: 4px;
  }

  .panel-details-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .panel-detail-item {
    font-size: var(--step--1);
    color: rgba(255, 255, 255, 0.85);
  }

  .panel-detail-item strong {
    color: var(--color-white);
  }

  /* 2. Manifesto Styling */
  .manifesto-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .manifesto-box {
    max-width: 900px;
    margin: 0 auto;
    border-left: 6px solid var(--color-lbs-red);
    padding-left: clamp(24px, 4vw, 48px);
  }

  .manifesto-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    line-height: 1.2;
    margin-bottom: 28px;
    color: var(--color-lbs-blue);
  }

  .manifesto-body p {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin-bottom: 20px;
    max-width: none;
  }

  /* Section Base Utility */
  .section-eyebrow {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-weight: 700;
    color: var(--color-lbs-red);
    display: block;
    margin-bottom: 12px;
  }

  .section-title {
    font-size: var(--step-3);
    color: var(--color-lbs-blue);
    margin-bottom: 16px;
    line-height: 1.2;
  }

  .section-desc {
    font-size: var(--step-0);
    color: var(--color-ink-soft);
    margin-bottom: 48px;
    max-width: 65ch;
  }

  /* 3. Pillars Styling */
  .pillars-section {
    background-color: var(--color-warm-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .pillars-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .pillars-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .pillar-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 40px;
    transition: var(--transition-smooth);
    position: relative;
  }

  .pillar-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background-color: var(--color-lbs-blue);
    transform: scaleX(0);
    transform-origin: left;
    transition: var(--transition-smooth);
  }

  .pillar-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-card);
    border-color: transparent;
  }

  .pillar-card:hover::before {
    transform: scaleX(1);
  }

  .pillar-num {
    font-family: var(--font-serif);
    font-size: var(--step-2);
    font-weight: 700;
    color: var(--color-lbs-red);
    margin-bottom: 20px;
  }

  .pillar-heading {
    font-size: var(--step-1);
    color: var(--color-lbs-blue);
    margin-bottom: 12px;
  }

  .pillar-text {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.6;
    margin-bottom: 0;
  }

  /* 4. Featured Teams Section */
  .featured-teams-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .featured-grid {
    display: flex;
    flex-direction: column;
    gap: 56px;
  }

  .featured-card {
    display: grid;
    grid-template-columns: 1fr;
    border: 1px solid var(--color-border);
    background-color: var(--color-warm-white);
    transition: var(--transition-smooth);
  }

  @media (min-width: 992px) {
    .featured-card {
      grid-template-columns: 1.2fr 0.8fr;
    }
    .featured-card:nth-child(even) {
      grid-template-columns: 0.8fr 1.2fr;
    }
    .featured-card:nth-child(even) .featured-card-content {
      order: 2;
    }
    .featured-card:nth-child(even) .featured-card-visual {
      order: 1;
      border-right: 1px solid var(--color-border);
      border-left: none;
    }
  }

  .featured-card:hover {
    box-shadow: var(--shadow-card);
    border-color: var(--color-lbs-blue);
  }

  .featured-card-content {
    padding: clamp(32px, 5vw, 64px);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
  }

  .featured-team-name {
    font-size: var(--step-2);
    color: var(--color-lbs-blue);
    margin-bottom: 12px;
  }

  .featured-team-tagline {
    font-size: var(--step-0);
    font-weight: 600;
    color: var(--color-lbs-red);
    margin-bottom: 24px;
    font-family: var(--font-sans);
  }

  .featured-team-desc {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    margin-bottom: 32px;
    line-height: 1.6;
  }

  .featured-team-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 24px;
    font-size: var(--step--2);
    color: var(--color-muted);
    margin-bottom: 32px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .featured-actions {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 24px;
  }

  .product-link-icon {
    font-size: var(--step--1);
    font-weight: bold;
    color: var(--color-lbs-blue);
    text-decoration: none;
  }

  .product-link-icon:hover {
    color: var(--color-lbs-red);
  }

  .featured-card-visual {
    background-color: var(--color-cloud);
    border-left: 1px solid var(--color-border);
    padding: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .visual-mock {
    width: 100%;
    max-width: 380px;
    background-color: var(--color-white);
    border: 1px solid var(--color-border-strong);
    box-shadow: 0 12px 32px rgba(20, 23, 93, 0.06);
    display: flex;
    flex-direction: column;
  }

  .mock-header {
    background-color: var(--color-cloud);
    border-bottom: 1px solid var(--color-border);
    padding: 8px 12px;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .mock-header .dot {
    width: 6px;
    height: 6px;
    background-color: var(--color-border-strong);
    border-radius: 50%;
  }

  .mock-url {
    font-size: 10px;
    color: var(--color-muted);
    margin-left: 8px;
    font-family: var(--font-sans);
  }

  .mock-body {
    padding: 32px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .mock-logo {
    font-family: var(--font-serif);
    font-size: var(--step-0);
    font-weight: 700;
    color: var(--color-lbs-blue);
    margin-bottom: 6px;
  }

  .mock-tagline {
    font-size: var(--step--2);
    color: var(--color-lbs-red);
    margin-bottom: 24px;
    font-weight: 600;
  }

  .mock-blocks {
    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .mock-blocks div {
    height: 8px;
    background-color: var(--color-cloud);
  }

  .mock-blocks div:nth-child(2) {
    width: 80%;
  }

  .mock-blocks div:nth-child(3) {
    width: 60%;
  }

  /* 5. Cohort Showcase Styling */
  .cohort-showcase-section {
    background-color: var(--color-warm-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .showcase-header {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin-bottom: 48px;
  }

  @media (min-width: 768px) {
    .showcase-header {
      flex-direction: row;
      justify-content: space-between;
      align-items: flex-end;
    }
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
  }

  @media (min-width: 768px) {
    .showcase-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 992px) {
    .showcase-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .team-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 32px;
    display: flex;
    flex-direction: column;
    transition: var(--transition-smooth);
  }

  .team-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-lbs-red);
    box-shadow: var(--shadow-card);
  }

  .team-card-category {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
    color: var(--color-lbs-red);
    margin-bottom: 12px;
    display: block;
  }

  .team-card-title {
    font-size: var(--step-1);
    color: var(--color-lbs-blue);
    margin-bottom: 12px;
  }

  .team-card-desc {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    margin-bottom: 24px;
    line-height: 1.5;
    flex-grow: 1;
  }

  .team-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-border);
    padding-top: 16px;
    font-size: var(--step--2);
  }

  .team-size {
    color: var(--color-muted);
    font-weight: 600;
    text-transform: uppercase;
  }

  .team-card-link {
