---
import Layout from '../layouts/Layout.astro';
import peopleData from '../data/people.json';

const mentors = peopleData.filter(p => p.role === 'Mentor');
---

<Layout 
  title="Technical & Product Mentors — LBS AI Lab" 
  description="Meet the mentors driving the success of LBS AI Lab. Experts in software scaling, machine learning, product design, and business launch."
>
  <!-- Hero Section -->
  <section class="mentors-hero" aria-label="Mentors Introduction">
    <div class="container">
      <span class="badge badge-red" style="margin-bottom: 20px;">Lab Mentorship</span>
      <h1 class="mentors-headline">Mentors helping teams build with focus.</h1>
      <p class="mentors-subheadline">
        Product and technical mentors support teams as they move from idea to prototype and from prototype to launch-ready product.
      </p>
    </div>
  </section>

  <!-- Mentors Directory Grid -->
  <section class="directory-section" aria-label="Mentor List">
    <div class="container">
      <div class="mentors-full-grid">
        {mentors.map(mentor => (
          <div class="mentor-full-card">
            <div class="mentor-header">
              <h2 class="mentor-name">{mentor.name}</h2>
              <span class="mentor-badge">{mentor.mentorType}</span>
            </div>
            
            <p class="mentor-desc">
              Providing hands-on review of database design, REST/GraphQL API setup, vector search indices, user acquisition metrics, and UX navigation.
            </p>

            <div class="mentor-secure-contact" data-user={mentor.email.split('@')[0]} data-domain={mentor.email.split('@')[1]}>
              Contact details hidden (safety filter)
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Strategic Philosophy on Mentorship -->
  <section class="philosophy-section" aria-label="Mentorship Focus">
    <div class="container asymmetrical-grid">
      <div>
        <span class="section-eyebrow">Intellectual Framework</span>
        <h2 class="section-title">Why mentoring matters in a venture lab</h2>
        <p>
          Building AI products is not just about engineering; it is about matching modern model capabilities with highly specific business transformations.
        </p>
        <p>
          Our mentors bring decades of combined experience in engineering, product strategy, venture growth, and institutional AI transformation. They act as critical sounding boards, forcing student builders to narrow their MVP scope, validate user assumptions, and construct robust, secure systems.
        </p>
      </div>

      <div class="join-mentors-sidebar">
        <div class="join-box">
          <h3 class="join-box-title">Become a Mentor</h3>
          <p class="join-box-text">
            Are you a technical architect, product manager, or venture operator building directly with AI?
          </p>
          <p class="join-box-text" style="margin-bottom: 24px;">
            We are always looking for expert product and tech mentors to guide future cohorts.
          </p>
          <a href="/contact/" class="btn btn-secondary" style="border-color: white; color: white; display: inline-block; width: 100%; text-align: center;">Get in touch &rarr;</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Mentors directory specific styles */
  .mentors-hero {
    background-color: var(--color-lbs-blue);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    color: var(--color-white);
    border-bottom: 6px solid var(--color-lbs-red);
  }

  .mentors-headline {
    color: var(--color-white);
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    margin-bottom: 24px;
    line-height: 1.15;
  }

  .mentors-subheadline {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-1);
    max-width: 800px;
    line-height: 1.5;
  }

  /* Mentors grid */
  .directory-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .mentors-full-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .mentors-full-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .mentor-full-card {
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-border);
    padding: clamp(24px, 4vw, 40px);
    display: flex;
    flex-direction: column;
    transition: var(--transition-smooth);
  }

  .mentor-full-card:hover {
    box-shadow: var(--shadow-card);
    border-color: var(--color-lbs-blue);
  }

  .mentor-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 16px;
  }

  .mentor-name {
    font-size: var(--step-1);
    color: var(--color-lbs-blue);
    margin-bottom: 0;
  }

  .mentor-badge {
    font-size: var(--step--2);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 8px;
    background-color: rgba(205, 13, 47, 0.08);
    color: var(--color-lbs-red);
    border: 1px solid rgba(205, 13, 47, 0.2);
    border-radius: var(--radius-badge);
  }

  .mentor-desc {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.6;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .mentor-secure-contact {
    font-size: var(--step--2);
    color: var(--color-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    border-top: 1px solid var(--color-border);
    padding-top: 16px;
    margin-top: auto;
  }

  /* Philosophy section */
  .philosophy-section {
    background-color: var(--color-warm-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
  }

  .join-mentors-sidebar {
    height: 100%;
    display: flex;
    align-items: center;
  }

  .join-box {
    background-color: var(--color-lbs-blue);
    color: var(--color-white);
    padding: 40px;
    border-top: 4px solid var(--color-lbs-red);
    width: 100%;
  }

  .join-box-title {
    color: var(--color-white);
    font-size: var(--step-1);
    margin-bottom: 16px;
    font-family: var(--font-serif);
  }

  .join-box-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step--1);
    line-height: 1.5;
    margin-bottom: 16px;
  }
</style>

<!-- Secure contact rendering -->
<script>
  const contactBlocks = document.querySelectorAll('.mentor-secure-contact');
  if (contactBlocks.length) {
    contactBlocks.forEach(block => {
      const user = block.getAttribute('data-user');
      const domain = block.getAttribute('data-domain');
      if (user && domain) {
        block.textContent = `${user} [at] ${domain}`;
        block.style.color = 'var(--color-ink-soft)';
      }
    });
  }
</script>
