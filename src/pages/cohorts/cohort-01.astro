---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import peopleData from '../../data/people.json';

// Fetch Cohort 01 Teams
const allTeams = await getCollection('teams');
const cohortTeams = allTeams.filter(t => t.data.cohort === 'cohort-01');

// Filter Cohort 01 mentors
const mentors = peopleData.filter(p => p.role === 'Mentor');
---

<Layout 
  title="Cohort 01 (Spring 2026) — LBS AI Lab Founding Batch" 
  description="Meet the founding cohort of LBS AI Lab, in partnership with Google DeepMind. Nine student teams building AI products across LBS campuses."
>
  <!-- Hero Section -->
  <section class="cohort-hero" aria-label="Cohort 01 Introduction">
    <div class="container">
      <span class="badge badge-red" style="margin-bottom: 20px;">Cohort 01 · In Partnership with Google DeepMind</span>
      <h1 class="cohort-headline">The founding cohort of LBS AI Lab.</h1>
      
      <p class="cohort-subheadline">
        From 10 April to 12 June 2026, nine student teams are building AI products designed to solve active LBS campus and operational use cases. In the new era of vibe coding and agentic assistants, we teach builders how to iterate rapidly in front of an active fraternity of 2,000 students.
      </p>

      <div class="cohort-metrics-grid">
        <div class="metric-block">
          <span class="metric-num">9</span>
          <span class="metric-lbl">Active Teams</span>
        </div>
        <div class="metric-block">
          <span class="metric-num">22</span>
          <span class="metric-lbl">Builders</span>
        </div>
        <div class="metric-block">
          <span class="metric-num">4</span>
          <span class="metric-lbl">Technical & Product Mentors</span>
        </div>
        <div class="metric-block">
          <span class="metric-num">Google</span>
          <span class="metric-lbl">DeepMind Partner</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Dynamic Teams Grid (No category filters, shows builder names and public emails) -->
  <section class="teams-grid-section" id="teams-section" aria-label="Cohort Teams">
    <div class="container">
      <span class="section-eyebrow">Cohort Portfolio</span>
      <h2 class="section-title">Nine ventures shipped</h2>
      <p class="section-desc">
        Explore the complete batch of products constructed during the Spring 2026 build sandbox.
      </p>

      <!-- Teams Cards Grid -->
      <div class="showcase-grid" id="teams-showcase-container">
        {cohortTeams.map(team => {
          return (
            <div class="team-card-wrap">
              <div class="team-card">
                <span class="team-card-category">{team.data.category}</span>
                <h3 class="team-card-title">{team.data.name}</h3>
                <p class="team-card-desc">{team.data.tagline}</p>
                
                <div class="team-builders-info">
                  <strong>Builders & Contact:</strong>
                  <ul class="builders-emails-list">
                    {team.data.members.map(m => (
                      <li>
                        <span class="builder-name">{m.name}</span>
                        <a href={`mailto:${m.email}`} class="builder-email">{m.email}</a>
                      </li>
                    ))}
                  </ul>
                </div>

                <div class="team-card-footer">
                  <span class="cohort-alliance-lbl">Google DeepMind partner</span>
                  <a href={`/teams/${team.id}/`} class="team-card-link">Profile &rarr;</a>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Mentor Block -->
  <section class="cohort-mentors-section" aria-label="Cohort Mentors">
    <div class="container">
      <div class="asymmetrical-grid">
        <div>
          <span class="section-eyebrow">Roster guidance</span>
          <h2 class="section-title">Cohort 01 Mentors</h2>
          <p>
            Experts from product, venture scaling, and engineering who guide students on prompt strategies, schema setup, and rapid iterations.
          </p>
          <div class="mentors-list-layout">
            {mentors.map(mentor => (
              <div class="mentor-row-card">
                <div class="mentor-row-info">
                  <h3 class="mentor-row-name">{mentor.name}</h3>
                  <span class="mentor-row-role">{mentor.mentorType}</span>
                </div>
                <p class="mentor-row-desc">
                  Working with teams weekly to review code, troubleshoot interface flows, and prepare for Showcase Day.
                </p>
                <a href={`mailto:${mentor.email}`} class="mentor-email-link">{mentor.email}</a>
              </div>
            ))}
          </div>
        </div>

        <div class="mentor-commitment-block">
          <div class="commitment-card">
            <h3 class="commit-title">Showcase Details</h3>
            <p class="commit-text">
              Cohort 01 concludes on **12 June 2026**.
            </p>
            <p class="commit-text">
              In this new era, building is easy—getting real feedback is what teaches. Teams will demo their live applications to LBS faculty, Google DeepMind researchers, and external operators.
            </p>
            <a href="/contact/" class="btn btn-secondary" style="border-color: white; color: white; display: inline-block; width: 100%; text-align: center;">Request Showcase Invite</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="cohort-cta-section" aria-label="September recruitment">
    <div class="container">
      <div class="cta-card">
        <span class="badge badge-red" style="margin-bottom: 16px;">Next Phase</span>
        <h2 class="cta-title">Build in the next cohort</h2>
        <p class="cta-desc">
          The September 2026 cohort will bring together a new group of LBS students ready to build with AI. Applications open late summer.
        </p>
        <a href="/apply/" class="btn btn-primary">Register interest for September 2026</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Cohort 01 detail styles */
  .cohort-hero {
    background-color: var(--color-lbs-blue);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    color: var(--color-white);
    border-bottom: 6px solid var(--color-lbs-red);
  }

  .cohort-headline {
    color: var(--color-white);
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    margin-bottom: 24px;
    line-height: 1.15;
  }

  .cohort-subheadline {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-1);
    max-width: 800px;
    line-height: 1.5;
    margin-bottom: 48px;
  }

  .cohort-metrics-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 32px;
    max-width: 800px;
  }

  @media (min-width: 768px) {
    .cohort-metrics-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .metric-block {
    display: flex;
    flex-direction: column;
  }

  .metric-num {
    font-family: var(--font-serif);
    font-size: var(--step-3);
    font-weight: 700;
    line-height: 1;
    color: var(--color-white);
    margin-bottom: 4px;
  }

  .metric-lbl {
    font-size: var(--step--2);
    color: rgba(255, 255, 255, 0.7);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 600;
  }

  /* Teams list section styling */
  .teams-grid-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .showcase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .showcase-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 992px) {
    .showcase-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .team-card-wrap {
    display: flex;
  }

  .team-card {
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-border);
    padding: 32px;
    display: flex;
    flex-direction: column;
    width: 100%;
    transition: var(--transition-smooth);
  }

  .team-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-lbs-red);
    box-shadow: var(--shadow-card);
  }

  .team-card-category {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 700;
    color: var(--color-lbs-red);
    margin-bottom: 12px;
    display: block;
  }

  .team-card-title {
    font-size: var(--step-1);
    color: var(--color-lbs-blue);
    margin-bottom: 12px;
  }

  .team-card-desc {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    margin-bottom: 24px;
    line-height: 1.5;
  }

  .team-builders-info {
    font-size: var(--step--2);
    color: var(--color-muted);
    border-top: 1px dashed var(--color-border);
    padding-top: 16px;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .team-builders-info strong {
    color: var(--color-lbs-blue);
    display: block;
    margin-bottom: 8px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .builders-emails-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .builders-emails-list li {
    display: flex;
    flex-direction: column;
  }

  .builders-emails-list .builder-name {
    font-weight: 700;
    color: var(--color-ink);
  }

  .builders-emails-list .builder-email {
    color: var(--color-lbs-blue);
    text-decoration: underline;
    margin-top: 2px;
  }

  .builders-emails-list .builder-email:hover {
    color: var(--color-lbs-red);
  }

  .team-card-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    border-top: 1px solid var(--color-border);
    padding-top: 16px;
    font-size: var(--step--2);
  }

  .cohort-alliance-lbl {
    color: var(--color-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .team-card-link {
    font-weight: bold;
    color: var(--color-lbs-blue);
    text-decoration: none;
  }

  .team-card-link:hover {
    color: var(--color-lbs-red);
  }

  /* Mentors styling */
  .cohort-mentors-section {
    background-color: var(--color-warm-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .mentors-list-layout {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 32px;
  }

  .mentor-row-card {
    background-color: var(--color-white);
    border: 1px solid var(--color-border);
    padding: 24px 32px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .mentor-row-info {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
    border-bottom: 1px solid var(--color-cloud);
    padding-bottom: 8px;
    width: 100%;
  }

  .mentor-row-name {
    font-size: var(--step-0);
    color: var(--color-lbs-blue);
  }

  .mentor-row-role {
    font-size: var(--step--2);
    color: var(--color-lbs-red);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .mentor-row-desc {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.5;
    margin-bottom: 12px;
  }

  .mentor-email-link {
    font-size: var(--step--2);
    color: var(--color-lbs-blue);
    text-decoration: underline;
  }

  .mentor-email-link:hover {
    color: var(--color-lbs-red);
  }

  .mentor-commitment-block {
    height: 100%;
    display: flex;
    align-items: center;
  }

  .commitment-card {
    background-color: var(--color-lbs-blue);
    color: var(--color-white);
    padding: 40px;
    border-top: 4px solid var(--color-lbs-red);
    width: 100%;
  }

  .commit-title {
    color: var(--color-white);
    font-size: var(--step-1);
    margin-bottom: 16px;
    font-family: var(--font-serif);
  }

  .commit-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step--1);
    line-height: 1.6;
    margin-bottom: 16px;
  }

  /* Closing CTA Section */
  .cohort-cta-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
  }

  .cta-card {
    background-color: var(--color-ink);
    color: var(--color-white);
    padding: clamp(32px, 6vw, 64px);
    text-align: center;
    border-left: 6px solid var(--color-lbs-red);
  }

  .cta-title {
    color: var(--color-white);
    font-size: var(--step-2);
    margin-bottom: 16px;
  }

  .cta-desc {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-0);
    max-width: 65ch;
    margin: 0 auto 32px auto;
    line-height: 1.6;
  }
</style>
