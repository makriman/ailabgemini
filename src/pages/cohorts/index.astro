---
import Layout from '../../layouts/Layout.astro';
import cohortsData from '../../data/cohorts.json';
---

<Layout 
  title="Cohorts Archive — LBS AI Lab Batches" 
  description="Explore active and future cohorts at LBS AI Lab, including schedules, student numbers, team rosters, and active mentors."
>
  <!-- Hero Section -->
  <section class="cohorts-hero" aria-label="Cohorts Introduction">
    <div class="container">
      <span class="badge badge-red" style="margin-bottom: 20px;">Cohorts Timeline</span>
      <h1 class="cohorts-headline">Cohorts of AI-native builders.</h1>
      <p class="cohorts-subheadline">
        Each cohort brings together LBS students building practical AI products across careers, learning, operations, campus life, funding, and venture opportunities.
      </p>
    </div>
  </section>

  <!-- Cohorts Archive Grid -->
  <section class="archive-section" aria-label="Cohort Batches">
    <div class="container">
      <div class="archive-grid">
        {cohortsData.map(cohort => (
          <div class={`cohort-batch-card ${cohort.status}`}>
            <div class="batch-meta">
              <span class={`status-badge badge-${cohort.status}`}>
                {cohort.status === 'current' ? 'Active founding cohort' : 'Upcoming Cohort'}
              </span>
              <span class="batch-season">{cohort.season}</span>
            </div>

            <h2 class="batch-title">{cohort.name}</h2>
            
            <p class="batch-timeline">
              <strong>Timeline:</strong> {cohort.startsAt} {cohort.endsAt ? `— ${cohort.endsAt}` : ''}
            </p>

            {cohort.status === 'current' ? (
              <div class="batch-stats">
                <div class="stat-box">
                  <span class="stat-number">{cohort.teamCount}</span>
                  <span class="stat-label">Active Teams</span>
                </div>
                <div class="stat-box">
                  <span class="stat-number">{cohort.participantCount}</span>
                  <span class="stat-label">Builders</span>
                </div>
                <div class="stat-box">
                  <span class="stat-number">{cohort.mentorCount}</span>
                  <span class="stat-label">Technical Mentors</span>
                </div>
              </div>
            ) : (
              <p class="batch-upcoming-desc">
                Applications for Cohort 02 will open to all current London Business School students. Balanced teams of developers, business planners, and designers will build AI products across 9 weeks.
              </p>
            )}

            <div class="batch-actions">
              {cohort.status === 'current' ? (
                <>
                  <a href="/cohorts/cohort-01/" class="btn btn-primary">Explore Cohort 01 Batch</a>
                  <a href="/teams/" class="btn btn-secondary">View Shipped Products</a>
                </>
              ) : (
                <>
                  <a href="/cohorts/cohort-02/" class="btn btn-primary">Review Batch Requirements</a>
                  <a href="/apply/" class="btn btn-secondary">Register Interest</a>
                </>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- General Timetable Info -->
  <section class="schedule-info-section" aria-label="Commitment Guidelines">
    <div class="container asymmetrical-grid">
      <div>
        <span class="section-eyebrow">Commitment & Structure</span>
        <h2 class="section-title">What to expect in a cohort</h2>
        <p>
          LBS AI Lab cohorts are designed to fit alongside full-time studies, but they require a serious commitment to execution. We operate like a venture-funded product team, keeping overhead low and building speed high.
        </p>
        <ul class="schedule-list">
          <li>
            <strong>Weekly Shipped Code:</strong> Teams must demonstrate incremental progress on their prototype weekly. We measure progress in live URLs, not slide decks.
          </li>
          <li>
            <strong>Mentor Reviews:</strong> Structured 1-on-1 calls with technical and product mentors to troubleshoot code blocks and UX bottlenecks.
          </li>
          <li>
            <strong>Sandbox Infrastructure:</strong> Access to shared API keys, serverless environments, and database clusters.
          </li>
          <li>
            <strong>Showcase Day:</strong> A high-profile public presentation to classmates, institutional stakeholders, and external technical operators.
          </li>
        </ul>
      </div>

      <div class="schedule-sidebar">
        <div class="requirements-box">
          <h3 class="req-title">Candidate Profile</h3>
          <p class="req-text">
            We look for current LBS students with founder-level drive, product vision, or software development background. 
          </p>
          <p class="req-text" style="margin-bottom: 0;">
            No formal engineering training is required, but you must be ready to work with APIs, build visual prototypes, and test directly with users.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Cohorts Page specific styles */
  .cohorts-hero {
    background-color: var(--color-lbs-blue);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    color: var(--color-white);
    border-bottom: 6px solid var(--color-lbs-red);
  }

  .cohorts-headline {
    color: var(--color-white);
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    margin-bottom: 24px;
    line-height: 1.15;
  }

  .cohorts-subheadline {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-1);
    max-width: 800px;
    line-height: 1.5;
  }

  /* Archive Section styling */
  .archive-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .archive-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  @media (min-width: 992px) {
    .archive-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  .cohort-batch-card {
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-border);
    padding: clamp(32px, 5vw, 48px);
    display: flex;
    flex-direction: column;
    transition: var(--transition-smooth);
  }

  .cohort-batch-card:hover {
    box-shadow: var(--shadow-card);
    border-color: var(--color-lbs-blue);
  }

  .cohort-batch-card.current {
    border-left: 6px solid var(--color-lbs-blue);
  }

  .cohort-batch-card.upcoming {
    border-left: 6px solid var(--color-lbs-red);
  }

  .batch-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 24px;
  }

  .status-badge {
    font-size: var(--step--2);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 8px;
    border-radius: var(--radius-badge);
  }

  .status-badge.badge-current {
    background-color: rgba(20, 23, 93, 0.08);
    color: var(--color-lbs-blue);
    border: 1px solid var(--color-border);
  }

  .status-badge.badge-upcoming {
    background-color: rgba(205, 13, 47, 0.08);
    color: var(--color-lbs-red);
    border: 1px solid rgba(205, 13, 47, 0.15);
  }

  .batch-season {
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--color-muted);
  }

  .batch-title {
    font-size: var(--step-2);
    color: var(--color-lbs-blue);
    margin-bottom: 12px;
  }

  .batch-timeline {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    margin-bottom: 28px;
  }

  .batch-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
    margin-bottom: 32px;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    padding: 20px 0;
  }

  .stat-box {
    text-align: center;
  }

  .stat-number {
    font-family: var(--font-serif);
    font-size: var(--step-2);
    font-weight: 700;
    color: var(--color-lbs-blue);
    display: block;
    line-height: 1;
    margin-bottom: 4px;
  }

  .stat-label {
    font-size: var(--step--2);
    color: var(--color-muted);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
  }

  .batch-upcoming-desc {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.6;
    margin-bottom: 32px;
    border-top: 1px solid var(--color-border);
    padding-top: 20px;
  }

  .batch-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    margin-top: auto;
  }

  /* Schedule section styling */
  .schedule-info-section {
    background-color: var(--color-warm-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
  }

  .schedule-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-top: 24px;
  }

  .schedule-list li {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.6;
    position: relative;
    padding-left: 24px;
  }

  .schedule-list li::before {
    content: '▪';
    position: absolute;
    left: 0;
    color: var(--color-lbs-red);
    font-size: var(--step-0);
    line-height: 1;
  }

  .schedule-sidebar {
    height: 100%;
    display: flex;
    align-items: center;
  }

  .requirements-box {
    background-color: var(--color-lbs-blue);
    color: var(--color-white);
    padding: 40px;
    border-top: 4px solid var(--color-lbs-red);
  }

  .req-title {
    color: var(--color-white);
    font-size: var(--step-1);
    margin-bottom: 16px;
    font-family: var(--font-serif);
  }

  .req-text {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step--1);
    line-height: 1.5;
    margin-bottom: 16px;
  }
</style>
