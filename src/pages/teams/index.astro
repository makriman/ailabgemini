---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allTeams = await getCollection('teams');

// Extract unique categories
const categories = ["All", ...new Set(allTeams.map(t => {
  const mainPart = t.data.category.split('/')[0].trim();
  return mainPart;
}))];
---

<Layout 
  title="Venture Directory — Shipped Products by LBS AI Lab" 
  description="Explore the portfolio of AI products created by London Business School student builders, covering career copilots, operations, admissions, and more."
>
  <!-- Hero Section -->
  <section class="teams-hero" aria-label="Teams Introduction">
    <div class="container">
      <span class="badge badge-red" style="margin-bottom: 20px;">Venture Portfolio</span>
      <h1 class="teams-headline">Products built by LBS AI Lab teams.</h1>
      <p class="teams-subheadline">
        Explore AI products created by students across cohorts, from internal LBS tools to venture-scale prototypes.
      </p>
    </div>
  </section>

  <!-- Interactive Directory Grid -->
  <section class="directory-section" aria-label="Product Gallery">
    <div class="container">
      <div class="filter-controls-bar">
        <div>
          <span class="filter-label-text">Select Category:</span>
          <div class="category-filters" role="tablist" aria-label="Venture categories">
            {categories.map((cat, idx) => (
              <button 
                class={`filter-btn ${idx === 0 ? 'active' : ''}`}
                data-category={cat === 'All' ? 'all' : cat.toLowerCase().replace(/[^a-z0-9]/g, '-')}
                role="tab"
                aria-selected={idx === 0 ? 'true' : 'false'}
              >
                {cat}
              </button>
            ))}
          </div>
        </div>
      </div>

      <!-- Grid of Cards -->
      <div class="teams-showcase-grid" id="teams-showcase-container">
        {allTeams.map(team => {
          const categorySlug = team.data.category.split('/')[0].trim().toLowerCase().replace(/[^a-z0-9]/g, '-');
          
          return (
            <div class="team-card-wrapper" data-cat={categorySlug}>
              <div class="team-portfolio-card">
                <div class="card-body-content">
                  <div class="card-header-row">
                    <span class="team-cat-tag">{team.data.category}</span>
                    <span class="cohort-tag">{team.data.cohortLabel}</span>
                  </div>
                  <h3 class="team-title">{team.data.name}</h3>
                  <p class="team-tagline">{team.data.tagline}</p>
                  <p class="team-summary-text">{team.data.summary}</p>
                </div>
                
                <div class="card-footer-row">
                  <span class="members-count">{team.data.members.length} Builders</span>
                  <div class="actions-group">
                    <a href={`/teams/${team.id}/`} class="btn btn-secondary" style="padding: 6px 14px; font-size: var(--step--2);">Details</a>
                    {team.data.productUrl && (
                      <a href={team.data.productUrl} target="_blank" rel="noopener noreferrer" class="live-action-link">
                        Live site &rarr;
                      </a>
                    )}
                  </div>
                </div>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- CTA September 2026 -->
  <section class="teams-cta-section" aria-label="Timetable CTA">
    <div class="container">
      <div class="cta-inner-card">
        <h2 class="cta-title">Want to build something of your own?</h2>
        <p class="cta-desc">
          Applications for Cohort 02 open late summer. Join a structured timeline, get technical guidance from mentors, and ship a live product to a public URL.
        </p>
        <a href="/apply/" class="btn btn-primary">Register Interest</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Teams page specific styles */
  .teams-hero {
    background-color: var(--color-lbs-blue);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    color: var(--color-white);
    border-bottom: 6px solid var(--color-lbs-red);
  }

  .teams-headline {
    color: var(--color-white);
    font-size: clamp(2rem, 4.5vw, 3.6rem);
    margin-bottom: 24px;
    line-height: 1.15;
  }

  .teams-subheadline {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-1);
    max-width: 800px;
    line-height: 1.5;
  }

  /* Portfolio section */
  .directory-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
    border-bottom: 1px solid var(--color-border);
  }

  .filter-controls-bar {
    margin-bottom: 48px;
    border-bottom: 1px solid var(--color-border);
    padding-bottom: 24px;
  }

  .filter-label-text {
    font-size: var(--step--2);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-muted);
    display: block;
    margin-bottom: 12px;
  }

  .category-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 12px;
  }

  .filter-btn {
    background-color: var(--color-warm-white);
    color: var(--color-lbs-blue);
    border: 1px solid var(--color-border);
    padding: 8px 16px;
    font-family: var(--font-sans);
    font-size: var(--step--2);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    transition: var(--transition-fast);
  }

  .filter-btn:hover {
    background-color: var(--color-cloud);
    border-color: var(--color-lbs-blue);
  }

  .filter-btn.active {
    background-color: var(--color-lbs-blue);
    color: var(--color-white);
    border-color: var(--color-lbs-blue);
  }

  .teams-showcase-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }

  @media (min-width: 768px) {
    .teams-showcase-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 992px) {
    .teams-showcase-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .team-card-wrapper {
    display: flex;
    transition: opacity 0.3s ease, transform 0.3s ease;
  }

  .team-portfolio-card {
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    width: 100%;
    transition: var(--transition-smooth);
  }

  .team-portfolio-card:hover {
    transform: translateY(-4px);
    border-color: var(--color-lbs-red);
    box-shadow: var(--shadow-card);
  }

  .card-body-content {
    padding: 32px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .card-header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 16px;
  }

  .team-cat-tag {
    font-size: var(--step--2);
    font-weight: 700;
    color: var(--color-lbs-red);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .cohort-tag {
    font-size: var(--step--2);
    font-weight: 600;
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .team-title {
    font-size: var(--step-1);
    color: var(--color-lbs-blue);
    margin-bottom: 8px;
    font-weight: 700;
  }

  .team-tagline {
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--color-ink);
    margin-bottom: 16px;
    line-height: 1.4;
  }

  .team-summary-text {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.5;
    margin-bottom: 0;
  }

  .card-footer-row {
    border-top: 1px solid var(--color-border);
    padding: 20px 32px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: var(--step--2);
  }

  .members-count {
    color: var(--color-muted);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .actions-group {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .live-action-link {
    font-weight: bold;
    color: var(--color-lbs-blue);
    text-decoration: none;
  }

  .live-action-link:hover {
    color: var(--color-lbs-red);
  }

  /* CTA */
  .teams-cta-section {
    background-color: var(--color-warm-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
  }

  .cta-inner-card {
    background-color: var(--color-lbs-blue);
    color: var(--color-white);
    padding: clamp(32px, 6vw, 64px);
    text-align: center;
    border-left: 6px solid var(--color-lbs-red);
  }

  .cta-title {
    color: var(--color-white);
    font-size: var(--step-2);
    margin-bottom: 16px;
  }

  .cta-desc {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-0);
    max-width: 65ch;
    margin: 0 auto 32px auto;
    line-height: 1.6;
  }
</style>

<!-- Category filter logic -->
<script>
  const filterButtons = document.querySelectorAll('.filter-btn');
  const teamCards = document.querySelectorAll('.team-card-wrapper');

  if (filterButtons.length && teamCards.length) {
    filterButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        filterButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        const selectedCat = btn.getAttribute('data-category');

        teamCards.forEach(card => {
          const cardCat = card.getAttribute('data-cat');
          
          if (selectedCat === 'all' || selectedCat === cardCat) {
            card.style.display = 'flex';
            setTimeout(() => {
              card.style.opacity = '1';
              card.style.transform = 'scale(1)';
            }, 50);
          } else {
            card.style.opacity = '0';
            card.style.transform = 'scale(0.95)';
            setTimeout(() => {
              card.style.display = 'none';
            }, 300);
          }
        });
      });
    });
  }
</script>
