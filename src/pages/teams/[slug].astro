---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const allTeams = await getCollection('teams');
  return allTeams.map(team => ({
    params: { slug: team.id },
    props: { team },
  }));
}

const { team } = Astro.props;
const { Content } = await render(team);
---

<Layout 
  title={`${team.data.name} — LBS AI Lab Venture Profile`} 
  description={team.data.tagline}
>
  <!-- Hero Section -->
  <section class="team-detail-hero" aria-label="Venture Header">
    <div class="container">
      <div class="hero-top-row">
        <a href="/teams/" class="back-link">&larr; Back to Directory</a>
        <span class="badge badge-red">Cohort 01 Project</span>
      </div>

      <h1 class="team-detail-title">{team.data.name}</h1>
      <p class="team-detail-tagline">{team.data.tagline}</p>

      <div class="team-meta-bar">
        <div class="meta-item">
          <span class="meta-label">Category</span>
          <span class="meta-val">{team.data.category}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Status</span>
          <span class="meta-val">{team.data.status}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Timeline</span>
          <span class="meta-val">{team.data.cohortLabel}</span>
        </div>
        <div class="meta-item">
          <span class="meta-label">Builders</span>
          <span class="meta-val">{team.data.members.length} Participants</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Venture Body details -->
  <section class="team-content-section" aria-label="Venture Details">
    <div class="container asymmetrical-grid">
      <div class="content-left-panel">
        <h2 class="content-heading">The Problem</h2>
        <p class="summary-paragraph">
          {team.data.summary}
        </p>

        <h2 class="content-heading" style="margin-top: 48px;">What the team is building</h2>
        <div class="markdown-body">
          <Content />
        </div>

        {team.data.productUrl && (
          <div class="action-block" style="margin-top: 48px;">
            <a href={team.data.productUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary">
              Launch Application URL
            </a>
          </div>
        )}
      </div>

      <div class="content-right-sidebar">
        <!-- Team Members Roster -->
        <div class="sidebar-box roster-box">
          <h3 class="sidebar-box-title">The Build Team</h3>
          <ul class="roster-list">
            {team.data.members.map(member => (
              <li class="roster-item">
                <span class="builder-name">{member.name}</span>
                <span class="builder-role">{member.role}</span>
                <!-- Safe obfuscated email block -->
                <span class="builder-secure-email" data-user={member.email.split('@')[0]} data-domain={member.email.split('@')[1]}>
                  Contact link hidden (safe filter)
                </span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Privacy Contact Policy -->
        <div class="sidebar-box contact-policy-box">
          <h3 class="sidebar-box-title">Connect with Team</h3>
          <p class="policy-text">
            To ensure the security and privacy of our student participants, raw emails are obfuscated from scraper bots. 
          </p>
          <p class="policy-text" style="margin-bottom: 24px;">
            Click the button below to generate a secure mailto window containing the team participants' addresses.
          </p>
          <button class="btn btn-secondary" id="secure-connect-btn" style="width: 100%; display: block; text-align: center;">
            Contact Team Safely
          </button>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Venture Profile styling */
  .team-detail-hero {
    background-color: var(--color-lbs-blue);
    padding-top: clamp(48px, 6vw, 80px);
    padding-bottom: clamp(64px, 8vw, 100px);
    color: var(--color-white);
    border-bottom: 6px solid var(--color-lbs-red);
  }

  .hero-top-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 32px;
  }

  .back-link {
    color: rgba(255, 255, 255, 0.7);
    text-decoration: none;
    font-size: var(--step--1);
    font-weight: 600;
    transition: var(--transition-fast);
  }

  .back-link:hover {
    color: var(--color-white);
  }

  .team-detail-title {
    color: var(--color-white);
    font-size: clamp(2rem, 5vw, 4rem);
    margin-bottom: 16px;
    line-height: 1.1;
  }

  .team-detail-tagline {
    color: rgba(255, 255, 255, 0.85);
    font-size: var(--step-1);
    max-width: 800px;
    line-height: 1.4;
    margin-bottom: 48px;
    font-family: var(--font-sans);
  }

  .team-meta-bar {
    display: grid;
    grid-template-columns: 1fr;
    gap: 24px;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    padding-top: 32px;
  }

  @media (min-width: 768px) {
    .team-meta-bar {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .meta-item {
    display: flex;
    flex-direction: column;
  }

  .meta-label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 6px;
    font-weight: 700;
  }

  .meta-val {
    font-size: var(--step--1);
    font-weight: 600;
    color: var(--color-white);
  }

  /* Content section */
  .team-content-section {
    background-color: var(--color-white);
    padding-top: clamp(64px, 8vw, 120px);
    padding-bottom: clamp(64px, 8vw, 120px);
  }

  .content-heading {
    font-size: var(--step-2);
    color: var(--color-lbs-blue);
    border-bottom: 2px solid var(--color-lbs-red);
    padding-bottom: 8px;
    margin-bottom: 24px;
  }

  .summary-paragraph {
    font-family: var(--font-serif);
    font-size: var(--step-1);
    line-height: 1.6;
    color: var(--color-lbs-blue);
    margin-bottom: 32px;
  }

  .markdown-body p {
    font-size: var(--step-0);
    line-height: 1.6;
    color: var(--color-ink-soft);
    margin-bottom: 20px;
  }

  /* Sidebar styling */
  .sidebar-box {
    background-color: var(--color-warm-white);
    border: 1px solid var(--color-border);
    padding: 32px;
    margin-bottom: 32px;
  }

  .sidebar-box-title {
    font-size: var(--step-0);
    color: var(--color-lbs-blue);
    margin-bottom: 20px;
    border-bottom: 1px solid var(--color-border-strong);
    padding-bottom: 8px;
  }

  .roster-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .roster-item {
    display: flex;
    flex-direction: column;
  }

  .builder-name {
    font-size: var(--step--1);
    font-weight: 700;
    color: var(--color-ink);
  }

  .builder-role {
    font-size: var(--step--2);
    color: var(--color-lbs-red);
    text-transform: uppercase;
    font-weight: 600;
    letter-spacing: 0.05em;
    margin-top: 2px;
  }

  .builder-secure-email {
    font-size: var(--step--2);
    color: var(--color-muted);
    margin-top: 4px;
    font-style: italic;
  }

  .contact-policy-box {
    background-color: var(--color-cloud);
  }

  .policy-text {
    font-size: var(--step--1);
    color: var(--color-ink-soft);
    line-height: 1.5;
  }
</style>

<!-- Email safe obfuscation client script -->
<script>
  // Setup safe mailto activation
  const connectBtn = document.getElementById('secure-connect-btn');
  const emailBlocks = document.querySelectorAll('.builder-secure-email');

  if (emailBlocks.length) {
    // Proactively render safe emails visually so human users can see them
    emailBlocks.forEach(block => {
      const user = block.getAttribute('data-user');
      const domain = block.getAttribute('data-domain');
      if (user && domain) {
        block.textContent = `${user} [at] ${domain}`;
        block.style.fontStyle = 'normal';
        block.style.color = 'var(--color-ink-soft)';
      }
    });
  }

  if (connectBtn && emailBlocks.length) {
    connectBtn.addEventListener('click', () => {
      // Gather all addresses
      const addresses = [];
      emailBlocks.forEach(block => {
        const user = block.getAttribute('data-user');
        const domain = block.getAttribute('data-domain');
        if (user && domain) {
          addresses.push(`${user}@${domain}`);
        }
      });

      if (addresses.length) {
        const mailtoString = `mailto:${addresses.join(',')}?subject=Inquiry regarding LBS AI Lab venture project`;
        window.location.href = mailtoString;
      }
    });
  }
</script>
